    "scenarios": {
        "s1": {
            "text": "\u0906\u092A\u0915\u093E \u0926\u094B\u0938\u094D\u0924 \u0906\u0916\u093F\u0930\u0940 \u0938\u092E\u092F \u092A\u0930 \u092F\u094B\u091C\u0928\u093E \u0930\u0926\u094D\u0926 \u0915\u0930 \u0926\u0947\u0924\u093E \u0939\u0948\u0964",
