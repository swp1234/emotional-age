        "s8": {
            "text": "\u0915\u094B\u0908 \u0906\u092A\u0915\u0947 \u0907\u0930\u093E\u0926\u094B\u0902 \u0915\u094B \u092A\u0942\u0930\u0940 \u0924\u0930\u0939 \u0917\u0932\u0924 \u0938\u092E\u091D\u0924\u093E \u0939\u0948\u0964",
