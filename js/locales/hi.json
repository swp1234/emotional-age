            "right": "\u0938\u092E\u091D\u0928\u093E \u0914\u0930 \u0936\u093E\u0902\u0924\u093F \u0938\u0947 \u0926\u094B\u092C\u093E\u0930\u093E \u092F\u094B\u091C\u0928\u093E \u092C\u0928\u093E\u0928\u093E"
        },
        "s2": {
            "text": "\u0915\u094B\u0908 \u0926\u0942\u0938\u0930\u094B\u0902 \u0915\u0947 \u0938\u093E\u092E\u0928\u0947 \u0906\u092A\u0915\u0947 \u0915\u093E\u092E \u0915\u0940 \u0906\u0932\u094B\u091A\u0928\u093E \u0915\u0930\u0924\u093E \u0939\u0948\u0964",
            "left": "\u092C\u091A\u093E\u0935 \u092E\u0947\u0902 \u0906\u0915\u0930 \u092C\u0939\u0938 \u0915\u0930\u0928\u093E",
            "right": "\u092B\u0940\u0921\u092C\u0948\u0915 \u0915\u0947 \u092A\u094D\u0930\u0924\u093F \u0916\u0941\u0932\u093E \u0930\u0939\u0928\u093E"
        },
        "s3": {
            "text": "\u0906\u092A\u0915\u0947 \u092A\u093E\u0930\u094D\u091F\u0928\u0930 \u0928\u0947 \u0918\u0902\u091F\u094B\u0902 \u0938\u0947 \u092E\u0948\u0938\u0947\u091C \u0915\u093E \u091C\u0935\u093E\u092C \u0928\u0939\u0940\u0902 \u0926\u093F\u092F\u093E\u0964",
            "left": "\u091A\u093F\u0902\u0924\u093E \u0915\u0947 \u091A\u0915\u094D\u0930 \u092E\u0947\u0902 \u092B\u0902\u0938\u0928\u093E",
            "right": "\u092D\u0930\u094B\u0938\u093E \u0915\u0930\u0928\u093E \u0914\u0930 \u0936\u093E\u0902\u0924 \u0930\u0939\u0928\u093E"
        },
        "s4": {
            "text": "\u0906\u092A \u0915\u093E\u092E \u092A\u0930 \u090F\u0915 \u092C\u0921\u093C\u0940 \u0917\u0932\u0924\u0940 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
            "left": "\u0906\u0924\u094D\u092E-\u0918\u0943\u0923\u093E \u0914\u0930 \u0936\u0930\u094D\u092E \u092E\u0947\u0902 \u0921\u0942\u092C\u0928\u093E",
            "right": "\u0906\u0924\u094D\u092E-\u0915\u0930\u0941\u0923\u093E \u0930\u0916\u0928\u093E \u0914\u0930 \u0920\u0940\u0915 \u0915\u0930\u0928\u093E"
        },
        "s5": {
            "text": "\u0915\u094B\u0908 \u0932\u093E\u0907\u0928 \u092E\u0947\u0902 \u0906\u092A\u0915\u0947 \u0906\u0917\u0947 \u0915\u091F \u091C\u093E\u0924\u093E \u0939\u0948\u0964",
