        "s9": {
            "text": "\u0906\u092A \u091C\u0940\u0935\u0928 \u092E\u0947\u0902 \u0938\u092C \u0915\u0941\u091B \u0938\u0947 \u092A\u0942\u0930\u0940 \u0924\u0930\u0939 \u0926\u092C\u0947 \u0939\u0941\u090F \u092E\u0939\u0938\u0942\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
