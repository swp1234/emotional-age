            "right": "\u091B\u094B\u0921\u093C \u0926\u0947\u0928\u093E, \u090A\u0930\u094D\u091C\u093E \u092C\u0930\u094D\u092C\u093E\u0926 \u0928\u0939\u0940\u0902"
        },
        "s6": {
            "text": "\u0906\u092A\u0915\u093E \u090F\u0915\u094D\u0938 \u0915\u093F\u0938\u0940 \u0928\u090F \u0935\u094D\u092F\u0915\u094D\u0924\u093F \u0915\u0947 \u0938\u093E\u0925 \u092B\u094B\u091F\u094B \u092A\u094B\u0938\u094D\u091F \u0915\u0930\u0924\u093E \u0939\u0948\u0964",
            "left": "\u091C\u0941\u0928\u0942\u0928 \u0939\u094B\u0915\u0930 \u092A\u094D\u0930\u094B\u092B\u093E\u0907\u0932 \u0926\u0947\u0916\u0928\u093E",
            "right": "\u0938\u091A\u092E\u0941\u091A \u0909\u0928\u0915\u0940 \u0916\u0941\u0936\u0940 \u092E\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093E"
        },
        "s7": {
            "text": "\u0906\u092A\u0915\u093E \u0926\u094B\u0938\u094D\u0924 \u0935\u094B \u0939\u093E\u0938\u093F\u0932 \u0915\u0930\u0924\u093E \u0939\u0948 \u091C\u094B \u0906\u092A \u0939\u092E\u0947\u0936\u093E \u091A\u093E\u0939\u0924\u0947 \u0925\u0947\u0964",
