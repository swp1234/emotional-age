{
    "meta": {
        "title": "\uAC10\uC815 \uB098\uC774 \uD14C\uC2A4\uD2B8 | DopaBrain",
        "description": "\uB2F9\uC2E0\uC758 \uAC10\uC815 \uC131\uC219\uB3C4\uB294? 10\uAC00\uC9C0 \uC2E4\uC81C \uC0C1\uD669\uC5D0\uC11C \uC2AC\uB77C\uC774\uB354\uB97C \uB4DC\uB798\uADF8\uD574 \uC9C4\uC9DC \uAC10\uC815 \uB098\uC774\uB97C \uC54C\uC544\uBCF4\uC138\uC694."
    },
    "a11y": {
        "skip": "\uBCF8\uBB38\uC73C\uB85C \uAC74\uB108\uB6F0\uAE30"
    },
    "app": {
        "title": "\uAC10\uC815 \uB098\uC774 \uD14C\uC2A4\uD2B8",
        "subtitle": "\uB2F9\uC2E0\uC758 \uB9C8\uC74C\uC740 \uBA87 \uC0B4\uC778\uAC00\uC694?",
        "description": "10\uAC00\uC9C0 \uAC10\uC815\uC801 \uC0C1\uD669\uC5D0\uC11C \uB450 \uBC18\uC751 \uC0AC\uC774\uC758 \uC2AC\uB77C\uC774\uB354\uB97C \uB4DC\uB798\uADF8\uD574 \uC9C4\uC9DC \uAC10\uC815 \uB098\uC774\uB97C \uC54C\uC544\uBCF4\uC138\uC694.",
        "start": "\uAC10\uC815 \uB098\uC774 \uC54C\uC544\uBCF4\uAE30"
    },
    "quiz": {
        "next": "\uB2E4\uC74C",
        "finish": "\uACB0\uACFC \uBCF4\uAE30"
    },
    "scenarios": {
        "s1": {
            "text": "\uCE5C\uAD6C\uAC00 \uB9C8\uC9C0\uB9C9 \uC21C\uAC04\uC5D0 \uC57D\uC18D\uC744 \uCDE8\uC18C\uD569\uB2C8\uB2E4.",
            "left": "\uD654\uB97C \uD3ED\uBC1C\uC2DC\uD0A8\uB2E4",
            "right": "\uC774\uD574\uD558\uACE0 \uCE68\uCC29\uD558\uAC8C \uC77C\uC815\uC744 \uB2E4\uC2DC \uC7A1\uB294\uB2E4"
        },
        "s2": {
            "text": "\uB204\uAD70\uAC00 \uB2E4\uB978 \uC0AC\uB78C\uB4E4 \uC55E\uC5D0\uC11C \uB2F9\uC2E0\uC758 \uC791\uC5C5\uC744 \uBE44\uD310\uD569\uB2C8\uB2E4.",
            "left": "\uBC29\uC5B4\uC801\uC73C\uB85C \uBC18\uBC15\uD55C\uB2E4",
            "right": "\uD53C\uB4DC\uBC31\uC744 \uC5F4\uB9B0 \uB9C8\uC74C\uC73C\uB85C \uBC1B\uC544\uB4E4\uC778\uB2E4"
        },
        "s3": {
            "text": "\uC5F0\uC778\uC774 \uBA87 \uC2DC\uAC04\uC9F8 \uBB38\uC790\uC5D0 \uB2F5\uC7A5\uC774 \uC5C6\uC2B5\uB2C8\uB2E4.",
            "left": "\uBD88\uC548\uC5D0 \uBE60\uC838 \uACFC\uB3C4\uD558\uAC8C \uC0DD\uAC01\uD55C\uB2E4",
            "right": "\uC2E0\uB8B0\uD558\uACE0 \uCE68\uCC29\uD568\uC744 \uC720\uC9C0\uD55C\uB2E4"
        },
        "s4": {
            "text": "\uC9C1\uC7A5\uC5D0\uC11C \uD070 \uC2E4\uC218\uB97C \uD588\uC2B5\uB2C8\uB2E4.",
            "left": "\uC790\uAE30\uD608\uC624\uC640 \uC218\uCE58\uC2EC\uC5D0 \uBE60\uC9C4\uB2E4",
            "right": "\uC790\uAE30 \uC5F0\uBBFC\uC744 \uAC16\uACE0 \uBB38\uC81C\uB97C \uD574\uACB0\uD55C\uB2E4"
        },
        "s5": {
            "text": "\uB204\uAD70\uAC00 \uC904\uC5D0\uC11C \uC0C8\uCE58\uAE30\uB97C \uD569\uB2C8\uB2E4.",
            "left": "\uACF5\uACA9\uC801\uC73C\uB85C \uB300\uB9BD\uD55C\uB2E4",
            "right": "\uADF8\uB0E5 \uB118\uAE34\uB2E4, \uC5D0\uB108\uC9C0 \uC544\uAE5C\uB2E4"
        },
        "s6": {
            "text": "\uC804 \uC560\uC778\uC774 \uC0C8\uB85C\uC6B4 \uC0AC\uB78C\uACFC \uCC0D\uC740 \uC0AC\uC9C4\uC744 \uC62C\uB838\uC2B5\uB2C8\uB2E4.",
            "left": "\uC9D1\uCC29\uD558\uBA70 \uD504\uB85C\uD544\uC744 \uC5FC\uD0D0\uD55C\uB2E4",
            "right": "\uC9C4\uC2EC\uC73C\uB85C \uADF8\uB4E4\uC758 \uD589\uBCF5\uC744 \uBC14\uB780\uB2E4"
        },
        "s7": {
            "text": "\uCE5C\uAD6C\uAC00 \uB2F9\uC2E0\uC774 \uD56D\uC0C1 \uC6D0\uD558\uB358 \uAC83\uC744 \uC774\uB904\uC5C8\uC2B5\uB2C8\uB2E4.",
            "left": "\uC9C8\uD22C\uC2EC\uC5D0 \uC0AC\uB85C\uC7A1\uD78C\uB2E4",
            "right": "\uC9C4\uC2EC\uC73C\uB85C \uCD95\uD558\uD574\uC900\uB2E4"
        },
        "s8": {
            "text": "\uB204\uAD70\uAC00 \uB2F9\uC2E0\uC758 \uC758\uB3C4\uB97C \uC644\uC804\uD788 \uC624\uD574\uD569\uB2C8\uB2E4.",
            "left": "\uC9DC\uC99D\uC774 \uB098\uC11C \uC124\uBA85\uC744 \uD3EC\uAE30\uD55C\uB2E4",
            "right": "\uACF5\uAC10\uC744 \uAC00\uC9C0\uACE0 \uCC28\uBD84\uD788 \uC124\uBA85\uD55C\uB2E4"
        },
        "s9": {
            "text": "\uC0B6\uC758 \uBAA8\uB4E0 \uAC83\uC5D0 \uC644\uC804\uD788 \uC555\uB3C4\uB2F9\uD558\uB294 \uB290\uB08C\uC785\uB2C8\uB2E4.",
            "left": "\uC704\uCD95\uB418\uC5B4 \uC2A4\uC2A4\uB85C\uB97C \uACE0\uB9BD\uC2DC\uD0A8\uB2E4",
            "right": "\uB3C4\uC6C0\uC744 \uAD6C\uD558\uACE0 \uCDA9\uBD84\uD788 \uC26C\uB3C4\uB85D \uD55C\uB2E4"
        },
        "s10": {
            "text": "\uBAA8\uB974\uB294 \uC0AC\uB78C\uC774 \uC774\uC720 \uC5C6\uC774 \uB2F9\uC2E0\uC5D0\uAC8C \uBB34\uB840\uD558\uAC8C \uAD70\uB2E4.",
            "left": "\uADF8\uB300\uB85C \uBB34\uB840\uD558\uAC8C \uB418\uAC11\uC544\uC900\uB2E4",
            "right": "\uADF8 \uC0AC\uB78C\uC774 \uD798\uB4E0 \uD558\uB8E8\uB97C \uBCF4\uB0B4\uACE0 \uC788\uC744 \uC218 \uC788\uB2E4\uACE0 \uC5F0\uBBFC\uD55C\uB2E4"
        }
    },
    "tiers": {
        "child": {
            "name": "\uAC10\uC815 \uC5B4\uB9B0\uC774",
            "emoji": "\uD83D\uDE22",
            "desc": "\uAC10\uC815\uC774 \uC6B4\uC804\uB300\uB97C \uC7A1\uACE0 \uC788\uC5B4\uC694! \uC5B4\uB9B0\uC774\uCC98\uB7FC \uC0DD\uAC01\uD558\uAE30 \uC804\uC5D0 \uBC18\uC751\uD569\uB2C8\uB2E4. \uAC10\uC815\uC774 \uC138\uACE0 \uBE60\uB974\uAC8C \uBC00\uB824\uC640\uC694. \uC88B\uC740 \uC18C\uC2DD\uC740? \uC778\uC2DD\uC774 \uC131\uC7A5\uC758 \uCCAB\uAC78\uC74C\uC774\uB77C\uB294 \uAC83!"
        },
        "teen": {
            "name": "\uAC10\uC815 10\uB300",
            "emoji": "\uD83D\uDE16",
            "desc": "\uAC10\uC815 \uAD00\uB9AC\uB97C \uBC30\uC6B0\uACE0 \uC788\uC9C0\uB9CC \uC544\uC9C1 \uACFC\uC815 \uC911\uC774\uC5D0\uC694. \uC798 \uB2E4\uB8E8\uB294 \uB54C\uB3C4 \uC788\uACE0, \uAC10\uC815\uC5D0 \uC555\uB3C4\uB2F9\uD558\uB294 \uB54C\uB3C4 \uC788\uC5B4\uC694."
        },
        "young": {
            "name": "\uAC10\uC815 \uCCAD\uB144",
            "emoji": "\uD83D\uDE0A",
            "desc": "\uC9C4\uC9DC \uAC10\uC815 \uC9C0\uB2A5\uC774 \uBC1C\uB2EC\uD558\uACE0 \uC788\uC5B4\uC694! \uB300\uCCB4\uB85C \uAC10\uC815\uC744 \uAD00\uB9AC\uD558\uACE0, \uACF5\uAC10\uC744 \uBCF4\uC5EC\uC8FC\uACE0, \uC131\uC7A5\uD558\uB294 \uC131\uC219\uD568\uC73C\uB85C \uAC08\uB4F1\uC744 \uB2E4\uB8F0 \uC218 \uC788\uC5B4\uC694."
        },
        "mature": {
            "name": "\uAC10\uC815 \uC131\uC219",
            "emoji": "\uD83E\uDDD8",
            "desc": "\uC544\uB984\uB2E4\uC6B4 \uADE0\uD615\uC5D0 \uB3C4\uB2EC\uD588\uC5B4\uC694. \uC790\uC2E0\uC758 \uAC10\uC815\uC744 \uC774\uD574\uD558\uACE0, \uAC74\uAC15\uD55C \uACBD\uACC4\uB97C \uC138\uC6B0\uACE0, \uACF5\uAC10\uACFC \uC9C0\uD61C\uB85C \uC0B6\uC5D0 \uB2E4\uAC00\uAC11\uB2C8\uB2E4."
        },
        "elder": {
            "name": "\uAC10\uC815 \uD604\uC790",
            "emoji": "\uD83E\uDDD3",
            "desc": "\uAE4A\uC740 \uAC10\uC815\uC801 \uC9C0\uD61C\uB97C \uAC00\uC9C0\uACE0 \uC788\uC5B4\uC694. \uC778\uC0DD\uC758 \uD3ED\uD48D\uC744 \uC6B0\uC544\uD558\uAC8C \uD5E4\uCCD0\uB098\uAC00\uACE0, \uC790\uC2E0\uC744 \uC783\uC9C0 \uC54A\uC73C\uBA74\uC11C \uD0C0\uC778\uC744 \uC704\uD55C \uACF5\uAC04\uC744 \uB9CC\uB4E4\uACE0, \uACE0\uD1B5\uC744 \uC131\uC7A5\uC73C\uB85C \uBC14\uAFC9\uB2C8\uB2E4."
        }
    },
